#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Book {
    int id;
    char name[50];
    char author[50];
    struct Book* next;
};

struct Book* head = NULL;

// Add Book
void addBook() {
    struct Book* newBook = (struct Book*)malloc(sizeof(struct Book));
    
    printf("Enter Book ID: ");
    scanf("%d", &newBook->id);
    
    printf("Enter Book Name: ");
    scanf("%s", newBook->name);
    
    printf("Enter Author Name: ");
    scanf("%s", newBook->author);

    newBook->next = head;
    head = newBook;

    printf("Book Added Successfully!\n");
}

// Display Books
void displayBooks() {
    struct Book* temp = head;
    
    if (temp == NULL) {
        printf("No books available.\n");
        return;
    }

    while (temp != NULL) {
        printf("\nID: %d\nName: %s\nAuthor: %s\n", temp->id, temp->name, temp->author);
        temp = temp->next;
    }
}

// Search Book
void searchBook() {
    int id;
    printf("Enter Book ID to search: ");
    scanf("%d", &id);

    struct Book* temp = head;

    while (temp != NULL) {
        if (temp->id == id) {
            printf("Book Found!\nName: %s\nAuthor: %s\n", temp->name, temp->author);
            return;
        }
        temp = temp->next;
    }

    printf("Book Not Found!\n");
}

// Delete Book
void deleteBook() {
    int id;
    printf("Enter Book ID to delete: ");
    scanf("%d", &id);

    struct Book *temp = head, *prev = NULL;

    while (temp != NULL && temp->id != id) {
        prev = temp;
        temp = temp->next;
    }

    if (temp == NULL) {
        printf("Book Not Found!\n");
        return;
    }

    if (prev == NULL) {
        head = temp->next;
    } else {
        prev->next = temp->next;
    }

    free(temp);
    printf("Book Deleted Successfully!\n");
}

// Sort Books by ID
void sortBooks() {
    struct Book *i, *j;
    int tempId;
    char tempName[50], tempAuthor[50];

    for (i = head; i != NULL; i = i->next) {
        for (j = i->next; j != NULL; j = j->next) {
            if (i->id > j->id) {
                tempId = i->id;
                strcpy(tempName, i->name);
                strcpy(tempAuthor, i->author);

                i->id = j->id;
                strcpy(i->name, j->name);
                strcpy(i->author, j->author);

                j->id = tempId;
                strcpy(j->name, tempName);
                strcpy(j->author, tempAuthor);
            }
        }
    }

    printf("Books Sorted Successfully!\n");
}

// Main Menu
int main() {
    int choice;

    while (1) {
        printf("\n--- Library Management System ---\n");
        printf("1. Add Book\n2. Display Books\n3. Search Book\n4. Delete Book\n5. Sort Books\n6. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: addBook(); break;
            case 2: displayBooks(); break;
            case 3: searchBook(); break;
            case 4: deleteBook(); break;
            case 5: sortBooks(); break;
            case 6: exit(0);
            default: printf("Invalid choice!\n");
        }
    }

    return 0;
}
